# backend/.env.example
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/ai-media-editor

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend URL (for emails, redirects)
FRONTEND_URL=http://localhost:3000

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_UPLOADS=ai-media-editor-uploads
S3_BUCKET_EXPORTS=ai-media-editor-exports

# Cloudinary (alternative to S3)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI Services
OPENAI_API_KEY=
STABILITY_API_KEY=
REPLICATE_API_TOKEN=
HUGGINGFACE_API_KEY=

# Google Cloud Vision (optional)
GOOGLE_APPLICATION_CREDENTIALS=

# Email
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@aimediaeditor.com
FROM_NAME=AI Media Editor

# SendGrid (production)
SENDGRID_API_KEY=

# Stripe (payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Logging
LOG_LEVEL=info
LOG_DIR=logs